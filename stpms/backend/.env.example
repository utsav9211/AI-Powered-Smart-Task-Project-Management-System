# Backend environment (copy to backend/.env)

# SQLite (default local)
DATABASE_URL=sqlite:///./stpms.db

# Optional (only if you use Redis features)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# Google Gemini API
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# CORS (preferred for production):
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-name.vercel.app
# Optional for Vercel preview deployments:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Backward-compatible single-origin setting:
# CORS_ORIGIN=http://localhost:3000
